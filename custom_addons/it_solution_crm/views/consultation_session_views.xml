<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_consultation_session_tree" model="ir.ui.view">
        <field name="name">it.consultation.session.tree</field>
        <field name="model">it.consultation.session</field>
        <field name="arch" type="xml">
            <tree decoration-success="outcome == 'successful'" decoration-warning="outcome == 'followup'">
                <field name="name"/><field name="consulted_at"/><field name="partner_id"/><field name="lead_id"/>
                <field name="consultant_user_id"/><field name="employee_id"/><field name="channel"/><field name="outcome"/>
                <field name="purchase_outcome"/><field name="customer_rating"/><field name="state"/>
            </tree>
        </field>
    </record>
    <record id="view_it_consultation_session_form" model="ir.ui.view">
        <field name="name">it.consultation.session.form</field>
        <field name="model">it.consultation.session</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_complete" type="object" string="Hoàn tất phiên tư vấn" class="oe_highlight" attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button name="action_cancel" type="object" string="Hủy" attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <div class="oe_title"><label for="name"/><h1><field name="name"/></h1></div>
                    <group>
                        <group string="Khách hàng và nhân sự">
                            <field name="lead_id"/><field name="partner_id" readonly="1"/><field name="consultant_user_id"/><field name="employee_id" readonly="1"/>
                        </group>
                        <group string="Thời gian và kênh">
                            <field name="consulted_at"/><field name="channel"/><field name="duration_minutes"/><field name="next_action_at"/>
                        </group>
                    </group>
                    <group><field name="customer_need"/><field name="advice_summary"/></group>
                    <group string="Kết quả có thể kiểm chứng">
                        <field name="outcome"/><field name="purchase_outcome"/><field name="customer_rating"/><field name="feedback_note"/>
                    </group>
                </sheet>
                <div class="oe_chatter"><field name="message_follower_ids" widget="mail_followers"/><field name="activity_ids" widget="mail_activity"/><field name="message_ids" widget="mail_thread"/></div>
            </form>
        </field>
    </record>
    <record id="view_it_consultation_session_search" model="ir.ui.view">
        <field name="name">it.consultation.session.search</field><field name="model">it.consultation.session</field>
        <field name="arch" type="xml"><search>
            <field name="partner_id"/><field name="consultant_user_id"/><field name="employee_id"/>
            <filter name="done" string="Đã hoàn tất" domain="[('state','=','done')]"/>
            <filter name="successful" string="Tư vấn đạt" domain="[('outcome','=','successful')]"/>
            <filter name="good_rating" string="Đánh giá tốt" domain="[('customer_rating','in',('4','5'))]"/>
            <filter name="no_order" string="Đạt nhưng chưa mua" domain="[('outcome','=','successful'),('purchase_outcome','=','not_ordered')]"/>
            <separator/><filter name="group_consultant" string="Theo nhân viên" context="{'group_by':'consultant_user_id'}"/>
            <filter name="group_outcome" string="Theo kết quả tư vấn" context="{'group_by':'outcome'}"/>
            <filter name="group_purchase" string="Theo kết quả mua" context="{'group_by':'purchase_outcome'}"/>
        </search></field>
    </record>
    <record id="view_it_consultation_session_graph" model="ir.ui.view">
        <field name="name">it.consultation.session.graph</field><field name="model">it.consultation.session</field>
        <field name="arch" type="xml"><graph string="Hiệu quả tư vấn theo nhân viên" type="bar"><field name="consultant_user_id"/><field name="id" type="measure"/></graph></field>
    </record>
    <record id="view_it_consultation_performance_graph" model="ir.ui.view">
        <field name="name">it.consultation.session.performance.graph</field>
        <field name="model">it.consultation.session</field>
        <field name="arch" type="xml">
            <graph string="Hiệu quả nhân viên tư vấn" type="bar">
                <field name="employee_id" type="row"/>
                <field name="session_count" type="measure"/>
                <field name="successful_count" type="measure"/>
                <field name="ordered_count" type="measure"/>
                <field name="successful_no_order_count" type="measure"/>
                <field name="good_rating_count" type="measure"/>
            </graph>
        </field>
    </record>
    <record id="view_it_consultation_performance_pivot" model="ir.ui.view">
        <field name="name">it.consultation.session.performance.pivot</field>
        <field name="model">it.consultation.session</field>
        <field name="arch" type="xml">
            <pivot string="Phân tích hiệu quả tư vấn">
                <field name="employee_id" type="row"/>
                <field name="outcome" type="col"/>
                <field name="session_count" type="measure"/>
                <field name="successful_count" type="measure"/>
                <field name="ordered_count" type="measure"/>
                <field name="successful_no_order_count" type="measure"/>
                <field name="good_rating_count" type="measure"/>
            </pivot>
        </field>
    </record>
    <record id="action_it_consultation_session" model="ir.actions.act_window">
        <field name="name">Phiên tư vấn khách hàng</field><field name="res_model">it.consultation.session</field>
        <field name="view_mode">tree,form,graph,pivot</field><field name="search_view_id" ref="view_it_consultation_session_search"/>
    </record>
    <record id="action_it_consultation_performance" model="ir.actions.act_window">
        <field name="name">Hiệu quả nhân viên tư vấn</field>
        <field name="res_model">it.consultation.session</field>
        <field name="view_mode">graph,pivot,tree,form</field>
        <field name="domain">[('state', '=', 'done')]</field>
        <field name="context">{'search_default_done': 1, 'search_default_group_consultant': 1}</field>
        <field name="search_view_id" ref="view_it_consultation_session_search"/>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'graph', 'view_id': ref('view_it_consultation_performance_graph')}),
            (0, 0, {'view_mode': 'pivot', 'view_id': ref('view_it_consultation_performance_pivot')}),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_it_consultation_session_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_it_consultation_session_form')})
        ]"/>
    </record>
</odoo>
