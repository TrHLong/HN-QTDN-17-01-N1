<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_it_solution_user" model="res.groups">
        <field name="name">QLKH - Nhân viên tư vấn</field>
        <field name="category_id" ref="base.module_category_sales_sales"/>
        <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
    </record>
    <record id="group_it_solution_presales" model="res.groups">
        <field name="name">QLCV - Kỹ sư Presales</field>
        <field name="category_id" ref="base.module_category_sales_sales"/>
        <field name="implied_ids" eval="[(4, ref('it_solution_crm.group_it_solution_user')), (4, ref('project.group_project_user'))]"/>
    </record>
    <record id="group_it_solution_manager" model="res.groups">
        <field name="name">Quản lý tư vấn giải pháp IT</field>
        <field name="category_id" ref="base.module_category_sales_sales"/>
        <field name="implied_ids" eval="[(4, ref('it_solution_crm.group_it_solution_presales')), (4, ref('sales_team.group_sale_salesman_all_leads')), (4, ref('project.group_project_manager'))]"/>
    </record>

    <record id="rule_consultation_own" model="ir.rule">
        <field name="name">Nhân viên chỉ xem phiên tư vấn của mình</field>
        <field name="model_id" ref="model_it_consultation_session"/>
        <field name="domain_force">[('consultant_user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('it_solution_crm.group_it_solution_user'))]"/>
    </record>
    <record id="rule_consultation_manager_all" model="ir.rule">
        <field name="name">Quản lý xem toàn bộ phiên tư vấn</field>
        <field name="model_id" ref="model_it_consultation_session"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('it_solution_crm.group_it_solution_manager'))]"/>
    </record>
</odoo>
